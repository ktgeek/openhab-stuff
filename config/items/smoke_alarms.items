Group                    Basement_SmokeCOAlarm                    "Basement Smoke Alarm"                          (Basement)                                                                       ["Equipment"]               {homekit="SmokeSensor,CarbonMonoxideSensor"}
Switch                   Basement_SmokeCOAlarm_Smoke_Detected     "Basement Smoke Detected"                       (Basement_SmokeCOAlarm)                                                          ["Point"]                   {channel="zwavejs:node:c503e1bad6:node111:notification-smoke-alarm-sensor-status", homekit="SmokeSensor.SmokeDetectedState"}
Switch                   Basement_SmokeCOAlarm_CO_Detected        "Basement CO Detected"                          (Basement_SmokeCOAlarm)                                                          ["Point"]                   {channel="zwavejs:node:c503e1bad6:node111:notification-co-alarm-sensor-status", homekit="CarbonMonoxideSensor.CarbonMonoxideDetectedState"}
Group:Switch:OR(ON,OFF)  Basement_SmokeCOAlarm_Smoke_Fault_Group  "Basement Smoke Alarm Fault"                    (Basement_SmokeCOAlarm)                                                          ["Point"]                   {homekit="SmokeSensor.FaultStatus"}
Group:Switch:OR(ON,OFF)  Basement_SmokeCOAlarm_CO_Fault_Group     "Basement CO Alarm Fault"                       (Basement_SmokeCOAlarm)                                                          ["Point"]                   {homekit="CarbonMonoxideSensor.FaultStatus"}
Switch                   Basement_SmokeCOAlarm_Smoke_Fault        "Basement Smoke Alarm Dust Fault"               (Basement_SmokeCOAlarm_Smoke_Fault_Group)                                        ["Point"]                   {channel="zwavejs:node:c503e1bad6:node111:notification-smoke-alarm-dust-in-device-status"}
Switch                   Basement_SmokeCOAlarm_CO_Fault           "Basement CO Alarm Maintenance Fault"           (Basement_SmokeCOAlarm_CO_Fault_Group)                                           ["Point"]                   {channel="zwavejs:node:c503e1bad6:node111:notification-co-alarm-maintenance-status"}
Switch                   Basement_SmokeCOAlarm_Hardware_Fault     "Basement Smoke Alarm Hardware Fault"           (Basement_SmokeCOAlarm_Smoke_Fault_Group, Basement_SmokeCOAlarm_CO_Fault_Group)  ["Point"]                   {channel="zwavejs:node:c503e1bad6:node111:notification-system-hardware-status"}
Number:Dimensionless     Basement_SmokeCOAlarm_BatteryLevel       "Basement Smoke Alarm Battery Level [%.1f %%]"  (Basement_SmokeCOAlarm)                                                          ["Measurement", "Battery"]  {unit="%", channel="zwavejs:node:c503e1bad6:node111:battery-level"}
Switch                   Basement_SmokeCOAlarm_BatteryLevel_Low   "Basement Smoke Alarm Battery Level isLow"      (Basement_SmokeCOAlarm)                                                          ["Point"]                   {channel="zwavejs:node:c503e1bad6:node111:battery-level" [profile="ruby:is_low_state", threshold="10"], homekit="SmokeSensor.BatteryLowStatus, CarbonMonoxideSensor.BatteryLowStatus"}

Group                    Upstairs_SmokeCOAlarm                    "Upstairs Smoke Alarm"                          (Upstairs)                                                                       ["Equipment"]               {homekit="SmokeSensor,CarbonMonoxideSensor"}
