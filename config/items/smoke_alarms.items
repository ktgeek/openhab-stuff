Group:Switch:OR(ON,OFF)  Upstairs_SmokeCOAlarm_Smoke_Fault_Group  "Upstairs Smoke Alarm Fault"                    (Upstairs_SmokeCOAlarm)                                                          ["Point"]                   {homekit="SmokeSensor.FaultStatus"}
Group:Switch:OR(ON,OFF)  Upstairs_SmokeCOAlarm_CO_Fault_Group     "Upstairs CO Alarm Fault"                       (Upstairs_SmokeCOAlarm)                                                          ["Point"]                   {homekit="CarbonMonoxideSensor.FaultStatus"}
Switch                   Upstairs_SmokeCOAlarm_Smoke_Fault        "Upstairs Smoke Alarm Dust Fault"               (Upstairs_SmokeCOAlarm_Smoke_Fault_Group)                                        ["Point"]                   {channel="zwavejs:node:c503e1bad6:node112:notification-smoke-alarm-dust-in-device-status"}
Switch                   Upstairs_SmokeCOAlarm_CO_Fault           "Upstairs CO Alarm Maintenance Fault"           (Upstairs_SmokeCOAlarm_CO_Fault_Group)                                           ["Point"]                   {channel="zwavejs:node:c503e1bad6:node112:notification-co-alarm-maintenance-status"}
Switch                   Upstairs_SmokeCOAlarm_Hardware_Fault     "Upstairs Smoke Alarm Hardware Fault"           (Upstairs_SmokeCOAlarm_Smoke_Fault_Group, Upstairs_SmokeCOAlarm_CO_Fault_Group)  ["Point"]                   {channel="zwavejs:node:c503e1bad6:node112:notification-system-hardware-status"}
Number:Dimensionless     Upstairs_SmokeCOAlarm_BatteryLevel       "Upstairs Smoke Alarm Battery Level [%.1f %%]"  (Upstairs_SmokeCOAlarm)                                                          ["Measurement", "Battery"]  {unit="%", channel="zwavejs:node:c503e1bad6:node112:battery-level"}
