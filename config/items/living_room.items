Group    FF_LivingRoom	      "Living Room"    <sofa>          (FF)               ["LivingRoom"]

Group LivingRoom_WallOutlet "Living Room Wall Outlet" <poweroutlet_us> (FF_LivingRoom) ["PowerOutlet"] { homekit="Outlet" }
Switch LivingRoom_Wall_Outlet_Switch "Living Room Wall Outlet" <poweroutlet_us> (Christmas_Lights, Christmas_Lights_All, LivingRoom_WallOutlet) ["Point"] { homekit="Outlet.OnState", alexa="Outlet", channel="zwavejs:node:c503e1bad6:node7:binary-switch-value" }
Number:Energy LivingRoom_WallOutlet_kWh "Living Room Wall Outlet Power [%.1f kWh]" (LivingRoom_WallOutlet) ["Point", "Energy"] { channel="zwavejs:node:c503e1bad6:node7:meter-value-65537" }
Number:Power LivingRoom_WallOutlet_Watts "Living Room Wall Outlet Power [%.1f W]" (LivingRoom_WallOutlet) ["Point", "Energy"] { channel="zwavejs:node:c503e1bad6:node7:meter-value-66049" }
Switch LivingRoom_WallOutlet_In_Use "Living Room Wall Outlet In Use [RB(outletinuse.rb):%s]" (LivingRoom_WallOutlet) ["Point"] { homekit="Outlet.InUseStatus", channel="zwavejs:node:c503e1bad6:node7:meter-value-66049" }

Color LivingRoom_Light_1_Color "Living Room Light 1" (FF_LivingRoom, Christmas_Lights, Christmas_Lights_All) ["Point"] { matter="ColorLight" [label="Living Room Light 1", fixedLabels="room=Living Room"], channel="mqtt:topic:26bcbec1ee:4a7ee3e8b3:color" }
Color LivingRoom_Light_2_Color "Living Room Light 2" (FF_LivingRoom, Christmas_Lights, Christmas_Lights_All) ["Point"] { matter="ColorLight" [label="Living Room Light 2", fixedLabels="room=Living Room"], channel="mqtt:topic:26bcbec1ee:99fe3ab847:color" }

Group LivingRoom_Scene_Switch_Group "Living Room Scene Switch" <switch> (FF_LivingRoom)
