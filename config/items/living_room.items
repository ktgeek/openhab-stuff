Number LivingRoom_Scene_Switch_Scene_2 "Living Room Scene Switch Scene 2" (LivingRoom_Scene_Switch_Group, Clear_Scenes) {channel="zwavejs:node:c503e1bad6:node65:central-scene-scene-002"}
Number LivingRoom_Scene_Switch_Scene_3 "Living Room Scene Switch Scene 3" (LivingRoom_Scene_Switch_Group, Clear_Scenes) {channel="zwavejs:node:c503e1bad6:node65:central-scene-scene-003"}
Number LivingRoom_Scene_Switch_Scene_4 "Living Room Scene Switch Scene 4" (LivingRoom_Scene_Switch_Group, Clear_Scenes) {channel="zwavejs:node:c503e1bad6:node65:central-scene-scene-004"}
Number LivingRoom_Scene_Switch_Scene_5 "Living Room Scene Switch Scene 5" (LivingRoom_Scene_Switch_Group, Clear_Scenes) {channel="zwavejs:node:c503e1bad6:node65:central-scene-scene-005"}
Number LivingRoom_Scene_Switch_Scene_6 "Living Room Scene Switch Scene 6" (LivingRoom_Scene_Switch_Group, Clear_Scenes) {channel="zwavejs:node:c503e1bad6:node65:central-scene-scene-006"}

Group LivingRoom_TableLight (FF_LivingRoom) ["PowerOutlet"]
Switch Living_Room_Table_Light_Switch "Living Room Table Light" <poweroutlet_us> (LivingRoom_TableLight) ["Switch"] { channel="homeassistant:device:26bcbec1ee:zigbee2mqtt_5F0x282c02bfffed992e:switch", homekit="Lighting", alexa="Lighting" }
