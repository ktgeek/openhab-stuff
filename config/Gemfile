# frozen_string_literal: true

source "https://rubygems.org"

group(:test) do
  # openhab-scripting >= 5.45 depends on a sentinel "openhab" gem pinned to the running core
  # version; that gem is normally injected by the live openHAB JVM and isn't resolvable from
  # rubygems.org outside it. This local stub (matching our installed core, 5.2.0) satisfies it
  # for `bundle install`/rspec/rubocop. Bump the stub's version if openHAB core is upgraded.
  gem "openhab", path: "vendor/openhab-stub"
  gem "openhab-scripting", "~> 5.48"
  gem "rspec", "~> 3.11"
  gem "rubocop"
  gem "rubocop-openhab-scripting"
  gem "rubocop-performance"
  gem "rubocop-rspec"
  gem "timecop", "~> 0.9"
end

group(:rules) do
  # include any gems you reference from `gemfile` calls in your rules so that
  # they'll already be available in the rules, and won't need to be
  # re-installed on every run, slowing down spec runs considerably
  gem "activesupport", "~> 8.1", require: false
  gem "minitest", "~> 5", require: false
end
